<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vesper.App.ViewModels"
        xmlns:inst="using:Vesper.Core.Instances"
        xmlns:acc="using:Vesper.Core.Accounts"
        xmlns:thm="using:Vesper.Core.Theming"
        x:Class="Vesper.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Vesper Launcher"
        Width="1180" Height="740"
        MinWidth="980" MinHeight="640"
        Background="{DynamicResource BgBaseBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterScreen">

  <Grid RowDefinitions="44,*">

    <Border Grid.Row="0" Name="TitleBar"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1"
            PointerPressed="OnTitleBarPressed">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">

        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                    Margin="16,0,0,0" VerticalAlignment="Center">
          <Border Width="20" Height="20" CornerRadius="6"
                  Background="{DynamicResource AccentBrush}" />
          <TextBlock Text="Vesper Launcher" FontWeight="SemiBold" FontSize="13"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     VerticalAlignment="Center" />
        </StackPanel>

        <Button Grid.Column="2" Name="AccountButton" Classes="chrome"
                Width="NaN" Padding="10,0" Margin="0,0,8,0"
                Command="{Binding Accounts.TogglePopupCommand}">
          <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
            <Border Width="24" Height="24" CornerRadius="7"
                    Background="{DynamicResource AccentDeepBrush}">
              <TextBlock Text="{Binding Accounts.SelectedInitial}"
                         FontSize="12" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="{Binding Accounts.SelectedName}" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="{Binding Accounts.SelectedKindLabel}" FontSize="10"
                         Foreground="{DynamicResource TextFaintBrush}" />
            </StackPanel>
            <Path Classes="icon" Width="14" Height="14"
                  Data="{StaticResource IconChevronDown}" />
          </StackPanel>
        </Button>

        <StackPanel Grid.Column="3" Orientation="Horizontal">
          <Button Classes="chrome" Click="OnMinimize">
            <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconMinimize}" />
          </Button>
          <Button Classes="chrome" Click="OnMaximize">
            <Path Classes="icon" Width="13" Height="13" Data="{StaticResource IconMaximize}" />
          </Button>
          <Button Classes="chrome danger" Click="OnClose">
            <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconClose}" />
          </Button>
        </StackPanel>

        <Popup PlacementTarget="{Binding #AccountButton}"
               Placement="BottomEdgeAlignedRight"
               IsLightDismissEnabled="True"
               IsOpen="{Binding Accounts.IsOpen, Mode=TwoWay}">
          <Border Background="{DynamicResource BgCardBrush}"
                  BorderBrush="{DynamicResource BorderStrongBrush}"
                  BorderThickness="1" CornerRadius="14" Padding="10"
                  Width="320" Margin="0,6,0,0">
            <StackPanel Spacing="8">

              <TextBlock Classes="label" Text="ACCOUNTS" Margin="6,4,0,0" />

              <ItemsControl ItemsSource="{Binding Accounts.Accounts}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="acc:Account">
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2">
                      <Button Grid.Column="0" Grid.ColumnSpan="2" Classes="nav" Padding="8"
                              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Accounts.SelectAccountCommand}"
                              CommandParameter="{Binding}">
                        <StackPanel Orientation="Horizontal" Spacing="9">
                          <Border Width="26" Height="26" CornerRadius="8"
                                  Background="{DynamicResource AccentDeepBrush}">
                            <TextBlock Text="{Binding Username[0]}" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                          </Border>
                          <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Username}" FontSize="12.5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding Kind}" FontSize="10"
                                       Foreground="{DynamicResource TextFaintBrush}" />
                          </StackPanel>
                        </StackPanel>
                      </Button>
                      <Button Grid.Column="2" Classes="chrome" Width="32" Height="32"
                              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Accounts.RemoveAccountCommand}"
                              CommandParameter="{Binding}">
                        <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconTrash}" />
                      </Button>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="0,4" />

              <StackPanel IsVisible="{Binding !Accounts.IsAddingLocal}" Spacing="6">
                <Button Classes="nav" Command="{Binding Accounts.AddMicrosoftCommand}"
                        IsEnabled="{Binding !Accounts.IsSigningIn}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="icon" Data="{StaticResource IconPlus}" />
                    <TextBlock Text="Add Microsoft account" VerticalAlignment="Center" FontSize="12.5" />
                  </StackPanel>
                </Button>
                <Button Classes="nav" Command="{Binding Accounts.BeginAddLocalCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Classes="icon" Data="{StaticResource IconPlus}" />
                    <TextBlock Text="Add local account" VerticalAlignment="Center" FontSize="12.5" />
                  </StackPanel>
                </Button>
              </StackPanel>

              <StackPanel IsVisible="{Binding Accounts.IsAddingLocal}" Spacing="8" Margin="4">
                <TextBlock Classes="label" Text="USERNAME" />
                <TextBox Classes="field" PlaceholderText="Any username you like"
                         Text="{Binding Accounts.NewLocalUsername, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Classes="primary" Padding="16,8" Content="Create"
                          Command="{Binding Accounts.ConfirmAddLocalCommand}" />
                  <Button Classes="ghost" Content="Cancel"
                          Command="{Binding Accounts.CancelAddLocalCommand}" />
                </StackPanel>
              </StackPanel>

              <Border IsVisible="{Binding Accounts.DeviceCode, Converter={x:Static ObjectConverters.IsNotNull}}"
                      Background="{DynamicResource BgElevatedBrush}" CornerRadius="10" Padding="12">
                <StackPanel Spacing="6">
                  <TextBlock Classes="label" Text="ENTER THIS CODE" />
                  <SelectableTextBlock Text="{Binding Accounts.DeviceCode}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" />
                  <SelectableTextBlock Text="{Binding Accounts.DeviceVerificationUri}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
              </Border>

              <TextBlock Text="{Binding Accounts.StatusMessage}" FontSize="11" Margin="6,0,6,4"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource TextMutedBrush}"
                         IsVisible="{Binding Accounts.StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />

            </StackPanel>
          </Border>
        </Popup>

      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="224,*">

      <Border Grid.Column="0" Background="{DynamicResource BgElevatedBrush}"
              BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
        <Grid RowDefinitions="*,Auto" Margin="12">
          <StackPanel Grid.Row="0" Spacing="4">

            <Button Classes="nav" Classes.active="{Binding IsPlayTab}"
                    Command="{Binding SelectTabCommand}" CommandParameter="Play">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <Path Classes="icon solid" Data="{StaticResource IconPlay}" />
                <TextBlock Text="Play" VerticalAlignment="Center" FontSize="13.5" />
              </StackPanel>
            </Button>

            <Button Classes="nav" Classes.active="{Binding IsServersTab}"
                    Command="{Binding SelectTabCommand}" CommandParameter="Servers">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <Path Classes="icon" Data="{StaticResource IconServer}" />
                <TextBlock Text="Servers" VerticalAlignment="Center" FontSize="13.5" />
              </StackPanel>
            </Button>

            <Button Classes="nav" Classes.active="{Binding IsSettingsTab}"
                    Command="{Binding SelectTabCommand}" CommandParameter="Settings">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <Path Classes="icon" Data="{StaticResource IconSettings}" />
                <TextBlock Text="Settings" VerticalAlignment="Center" FontSize="13.5" />
              </StackPanel>
            </Button>

          </StackPanel>

          <StackPanel Grid.Row="1" Spacing="2" Margin="6,0,0,4">
            <TextBlock Text="{Binding StatusText}" FontSize="11" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Text="{Binding Version, StringFormat='Version {0}'}" FontSize="10"
                       Foreground="{DynamicResource TextFaintBrush}" />
          </StackPanel>
        </Grid>
      </Border>

      <Panel Grid.Column="1">

        <Grid IsVisible="{Binding IsPlayTab}" ColumnDefinitions="280,*" Margin="0">

          <Border Grid.Column="0" Background="{DynamicResource BgBaseBrush}"
                  BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto" Margin="14">
              <TextBlock Grid.Row="0" Classes="label" Text="INSTANCES" Margin="4,4,0,10" />

              <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding Instances}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="inst:Instance">
                      <Button Classes="nav" Margin="0,2"
                              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectInstanceCommand}"
                              CommandParameter="{Binding}">
                        <StackPanel Orientation="Horizontal" Spacing="11">
                          <Path Classes="icon" Data="{StaticResource IconBox}" />
                          <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock FontSize="10.5" Foreground="{DynamicResource TextFaintBrush}">
                              <Run Text="{Binding MinecraftVersion}" />
                              <Run Text="  " />
                              <Run Text="{Binding ProfileLabel}" />
                            </TextBlock>
                          </StackPanel>
                        </StackPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>

              <StackPanel Grid.Row="2" Spacing="7" Margin="0,12,0,0">
                <TextBox Classes="field" PlaceholderText="Instance name"
                         Text="{Binding NewInstanceName, Mode=TwoWay}" />
                <TextBox Classes="field" PlaceholderText="Version"
                         Text="{Binding NewInstanceVersion, Mode=TwoWay}" />
                <Button Classes="ghost" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding CreateInstanceCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Path Classes="icon" Width="15" Height="15" Data="{StaticResource IconPlus}" />
                    <TextBlock Text="New instance" FontSize="12.5" />
                  </StackPanel>
                </Button>
              </StackPanel>
            </Grid>
          </Border>

          <Grid Grid.Column="1" RowDefinitions="*,Auto" Margin="34,28,34,28">

            <StackPanel Grid.Row="0" VerticalAlignment="Center" Spacing="10">
              <TextBlock Classes="label" Text="SELECTED INSTANCE" />
              <TextBlock Classes="title" FontSize="34"
                         Text="{Binding SelectedInstance.Name, FallbackValue='No instance yet'}" />
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="8" Padding="10,5">
                  <TextBlock FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                             Text="{Binding SelectedInstance.MinecraftVersion, FallbackValue='—'}" />
                </Border>
                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="8" Padding="10,5">
                  <TextBlock FontSize="12" Foreground="{DynamicResource AccentBrush}"
                             Text="{Binding SelectedInstance.ProfileLabel, FallbackValue='—'}" />
                </Border>
              </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="14">
              <ProgressBar Value="{Binding Progress}" Maximum="100" Height="4"
                           IsVisible="{Binding IsBusy}"
                           Foreground="{DynamicResource AccentBrush}"
                           Background="{DynamicResource BgCardBrush}" />
              <Button Classes="primary" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"
                      FontSize="17" Padding="0,18"
                      IsEnabled="{Binding !IsBusy}"
                      Command="{Binding LaunchCommand}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                  <Path Classes="icon solid" Width="18" Height="18"
                        Fill="{DynamicResource AccentContrastBrush}"
                        Data="{StaticResource IconPlay}" />
                  <TextBlock Text="PLAY" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </StackPanel>

          </Grid>
        </Grid>

        <ScrollViewer IsVisible="{Binding IsServersTab}">
          <StackPanel Margin="34,28" Spacing="18">
            <TextBlock Classes="title" Text="Servers" />
            <TextBlock Classes="subtitle" TextWrapping="Wrap"
                       Text="Run a Paper or Purpur server locally, manage plugins and mods, and expose it over a playit.gg tunnel or your own domain." />
            <Border Classes="card">
              <StackPanel Spacing="12">
                <TextBlock Classes="label" Text="CONTROLS" />
                <StackPanel Orientation="Horizontal" Spacing="9">
                  <Button Classes="primary" Padding="16,10" IsEnabled="False">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Path Classes="icon solid" Width="14" Height="14"
                            Fill="{DynamicResource AccentContrastBrush}"
                            Data="{StaticResource IconPlay}" />
                      <TextBlock Text="Start" />
                    </StackPanel>
                  </Button>
                  <Button Classes="ghost" IsEnabled="False">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconStop}" />
                      <TextBlock Text="Stop" />
                    </StackPanel>
                  </Button>
                  <Button Classes="ghost" IsEnabled="False">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconRefresh}" />
                      <TextBlock Text="Restart" />
                    </StackPanel>
                  </Button>
                  <Button Classes="ghost" IsEnabled="False">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconGlobe}" />
                      <TextBlock Text="Tunnel" />
                    </StackPanel>
                  </Button>
                </StackPanel>
                <TextBlock Classes="subtitle" Text="Server management lands in the next milestone." />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer IsVisible="{Binding IsSettingsTab}">
          <StackPanel Margin="34,28" Spacing="18" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Classes="title" Text="Settings" />

            <Border Classes="card">
              <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Path Classes="icon" Data="{StaticResource IconPalette}" />
                  <TextBlock Text="Theme" FontSize="15" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <TextBlock Classes="subtitle"
                           Text="Every surface binds to theme tokens, so changing a theme recolours the whole app instantly." />
                <ItemsControl ItemsSource="{Binding Themes}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="thm:VesperTheme">
                      <Button Classes="nav" Margin="0,2"
                              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ApplyThemeCommand}"
                              CommandParameter="{Binding}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                          <Path Classes="icon" Data="{StaticResource IconPalette}" />
                          <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13" />
                        </StackPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Classes="card">
              <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Path Classes="icon" Data="{StaticResource IconFolder}" />
                  <TextBlock Text="Minecraft" FontSize="15" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <TextBlock Classes="label" Text="INSTALL DIRECTORY" />
                <SelectableTextBlock Text="{Binding RootDirectory}" FontSize="12"
                                     TextWrapping="Wrap"
                                     Foreground="{DynamicResource TextMutedBrush}" />
                <TextBlock Classes="subtitle"
                           Text="Game files, libraries and assets stay here. Nothing is written to the default .minecraft folder." />
              </StackPanel>
            </Border>

          </StackPanel>
        </ScrollViewer>

      </Panel>
    </Grid>
  </Grid>
</Window>
