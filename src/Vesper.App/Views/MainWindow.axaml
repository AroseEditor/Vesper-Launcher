<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vesper.App.ViewModels"
        xmlns:views="using:Vesper.App.Views"
        xmlns:acc="using:Vesper.Core.Accounts"
        x:Class="Vesper.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Vesper Launcher"
        Width="1240" Height="780"
        MinWidth="1060" MinHeight="680"
        Background="{DynamicResource BgBaseBrush}"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterScreen">

  <Grid RowDefinitions="46,*">

    <Border Grid.Row="0" Name="TitleBar"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1"
            PointerPressed="OnTitleBarPressed">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">

        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="11"
                    Margin="15,0,0,0" VerticalAlignment="Center">
          <Image Source="avares://VesperLauncher/Assets/icon.png" Width="24" Height="24" />
          <TextBlock Text="Vesper Launcher" FontWeight="SemiBold" FontSize="13.5"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     VerticalAlignment="Center" />
        </StackPanel>

        <Button Grid.Column="2" Name="AccountButton" Classes="chrome"
                Width="NaN" Padding="9,0" Margin="0,6,10,6"
                Command="{Binding Accounts.TogglePopupCommand}">
          <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
            <Border Width="26" Height="26" CornerRadius="8" ClipToBounds="True"
                    Background="{DynamicResource AccentDeepBrush}">
              <Panel>
                <TextBlock Text="{Binding Accounts.SelectedInitial}"
                           FontSize="12" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsVisible="{Binding !Accounts.HasAvatar}" />
                <Image Source="{Binding Accounts.SelectedAvatar}"
                       Width="26" Height="26"
                       RenderOptions.BitmapInterpolationMode="None"
                       IsVisible="{Binding Accounts.HasAvatar}" />
              </Panel>
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="{Binding Accounts.SelectedName}" FontSize="12.5" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="{Binding Accounts.SelectedKindLabel}" FontSize="10"
                         Foreground="{DynamicResource TextFaintBrush}" />
            </StackPanel>
            <Path Classes="icon" Width="14" Height="14"
                  Data="{StaticResource IconChevronDown}" />
          </StackPanel>
        </Button>

        <StackPanel Grid.Column="3" Orientation="Horizontal">
          <Button Classes="chrome" Click="OnMinimize">
            <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconMinimize}" />
          </Button>
          <Button Classes="chrome" Click="OnMaximize">
            <Path Classes="icon" Width="13" Height="13" Data="{StaticResource IconMaximize}" />
          </Button>
          <Button Classes="chrome danger" Click="OnClose">
            <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconClose}" />
          </Button>
        </StackPanel>

        <Popup PlacementTarget="{Binding #AccountButton}"
               Placement="BottomEdgeAlignedRight"
               IsLightDismissEnabled="True"
               IsOpen="{Binding Accounts.IsOpen, Mode=TwoWay}">
          <Border Classes="popIn"
                  Background="{DynamicResource BgCardBrush}"
                  BorderBrush="{DynamicResource BorderStrongBrush}"
                  BorderThickness="1" CornerRadius="15" Padding="11"
                  Width="330" Margin="0,7,0,0">
            <StackPanel Spacing="8">

              <TextBlock Classes="label" Text="ACCOUNTS" Margin="6,4,0,0" />

              <ItemsControl ItemsSource="{Binding Accounts.Accounts}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="acc:Account">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                      <Button Grid.Column="0" Classes="nav" Padding="8"
                              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Accounts.SelectAccountCommand}"
                              CommandParameter="{Binding}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                          <Border Width="28" Height="28" CornerRadius="8"
                                  Background="{DynamicResource AccentDeepBrush}">
                            <TextBlock Text="{Binding Username[0]}" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                          </Border>
                          <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Username}" FontSize="12.5"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding Kind}" FontSize="10"
                                       Foreground="{DynamicResource TextFaintBrush}" />
                          </StackPanel>
                        </StackPanel>
                      </Button>
                      <Button Grid.Column="1" Classes="chrome" Width="32" Height="32"
                              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Accounts.RemoveAccountCommand}"
                              CommandParameter="{Binding}">
                        <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconTrash}" />
                      </Button>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="0,4" />

              <StackPanel IsVisible="{Binding !Accounts.IsAddingLocal}" Spacing="5">
                <Button Classes="nav" Command="{Binding Accounts.AddMicrosoftCommand}"
                        IsEnabled="{Binding !Accounts.IsSigningIn}">
                  <StackPanel Orientation="Horizontal" Spacing="11">
                    <Path Classes="icon" Data="{StaticResource IconPlus}" />
                    <TextBlock Text="Add Microsoft account" VerticalAlignment="Center" FontSize="12.5" />
                  </StackPanel>
                </Button>
                <Button Classes="nav" Command="{Binding Accounts.BeginAddLocalCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="11">
                    <Path Classes="icon" Data="{StaticResource IconPlus}" />
                    <TextBlock Text="Add local account" VerticalAlignment="Center" FontSize="12.5" />
                  </StackPanel>
                </Button>
              </StackPanel>

              <StackPanel IsVisible="{Binding Accounts.IsAddingLocal}" Spacing="9" Margin="4">
                <TextBlock Classes="label" Text="USERNAME" />
                <TextBox Classes="field" PlaceholderText="Any username you like"
                         Text="{Binding Accounts.NewLocalUsername, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Classes="primary" Padding="17,8" Content="Create"
                          Command="{Binding Accounts.ConfirmAddLocalCommand}" />
                  <Button Classes="ghost" Content="Cancel"
                          Command="{Binding Accounts.CancelAddLocalCommand}" />
                </StackPanel>
              </StackPanel>

              <Border IsVisible="{Binding Accounts.DeviceCode, Converter={x:Static ObjectConverters.IsNotNull}}"
                      Background="{DynamicResource BgElevatedBrush}" CornerRadius="11" Padding="13">
                <StackPanel Spacing="6">
                  <TextBlock Classes="label" Text="ENTER THIS CODE" />
                  <SelectableTextBlock Text="{Binding Accounts.DeviceCode}"
                                       FontSize="21" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" />
                  <SelectableTextBlock Text="{Binding Accounts.DeviceVerificationUri}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
              </Border>

              <TextBlock Text="{Binding Accounts.StatusMessage}" FontSize="11" Margin="6,0,6,4"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource TextMutedBrush}"
                         IsVisible="{Binding Accounts.StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />

            </StackPanel>
          </Border>
        </Popup>

      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="228,*">

      <Border Grid.Column="0" Background="{DynamicResource BgElevatedBrush}"
              BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
        <Grid RowDefinitions="*,Auto" Margin="12,14,12,12">
          <StackPanel Grid.Row="0" Spacing="3">

            <Grid ColumnDefinitions="3,*">
              <Border Grid.Column="0" Classes="navPip" Classes.on="{Binding IsPlayTab}" Margin="0,9" />
              <Button Grid.Column="1" Classes="nav" Classes.active="{Binding IsPlayTab}"
                      Command="{Binding SelectTabCommand}" CommandParameter="Play">
                <StackPanel Orientation="Horizontal" Spacing="13">
                  <Path Classes="icon solid" Data="{StaticResource IconPlay}" />
                  <TextBlock Text="Play" VerticalAlignment="Center" FontSize="13.5" />
                </StackPanel>
              </Button>
            </Grid>

            <Grid ColumnDefinitions="3,*">
              <Border Grid.Column="0" Classes="navPip" Classes.on="{Binding IsSkinsTab}" Margin="0,9" />
              <Button Grid.Column="1" Classes="nav" Classes.active="{Binding IsSkinsTab}"
                      Command="{Binding SelectTabCommand}" CommandParameter="Skins">
                <StackPanel Orientation="Horizontal" Spacing="13">
                  <Path Classes="icon" Data="{StaticResource IconUser}" />
                  <TextBlock Text="Skins" VerticalAlignment="Center" FontSize="13.5" />
                </StackPanel>
              </Button>
            </Grid>

            <Grid ColumnDefinitions="3,*">
              <Border Grid.Column="0" Classes="navPip" Classes.on="{Binding IsServersTab}" Margin="0,9" />
              <Button Grid.Column="1" Classes="nav" Classes.active="{Binding IsServersTab}"
                      Command="{Binding SelectTabCommand}" CommandParameter="Servers">
                <StackPanel Orientation="Horizontal" Spacing="13">
                  <Path Classes="icon" Data="{StaticResource IconServer}" />
                  <TextBlock Text="Servers" VerticalAlignment="Center" FontSize="13.5" />
                </StackPanel>
              </Button>
            </Grid>

            <Grid ColumnDefinitions="3,*">
              <Border Grid.Column="0" Classes="navPip" Classes.on="{Binding IsSettingsTab}" Margin="0,9" />
              <Button Grid.Column="1" Classes="nav" Classes.active="{Binding IsSettingsTab}"
                      Command="{Binding SelectTabCommand}" CommandParameter="Settings">
                <StackPanel Orientation="Horizontal" Spacing="13">
                  <Path Classes="icon" Data="{StaticResource IconSettings}" />
                  <TextBlock Text="Settings" VerticalAlignment="Center" FontSize="13.5" />
                </StackPanel>
              </Button>
            </Grid>

          </StackPanel>

          <StackPanel Grid.Row="1" Spacing="3" Margin="6,0,0,2">
            <TextBlock Text="{Binding StatusText}" FontSize="11" TextWrapping="Wrap"
                       MaxLines="3" TextTrimming="CharacterEllipsis"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Text="{Binding Version, StringFormat='Vesper {0}'}" FontSize="10"
                       Foreground="{DynamicResource TextFaintBrush}" />
          </StackPanel>
        </Grid>
      </Border>

      <TransitioningContentControl Grid.Column="1" Content="{Binding CurrentPage}">
        <TransitioningContentControl.PageTransition>
          <CrossFade Duration="0:0:0.22" />
        </TransitioningContentControl.PageTransition>
        <TransitioningContentControl.DataTemplates>
          <DataTemplate DataType="vm:PlayViewModel">
            <views:PlayView />
          </DataTemplate>
          <DataTemplate DataType="vm:SkinsViewModel">
            <views:SkinsView />
          </DataTemplate>
          <DataTemplate DataType="vm:ServersViewModel">
            <views:ServersView />
          </DataTemplate>
          <DataTemplate DataType="vm:SettingsViewModel">
            <views:SettingsView />
          </DataTemplate>
        </TransitioningContentControl.DataTemplates>
      </TransitioningContentControl>

    </Grid>
  </Grid>
</Window>
