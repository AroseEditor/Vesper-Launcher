<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vesper.App.ViewModels"
             xmlns:srv="using:Vesper.Core.Servers"
             xmlns:sys="using:System"
             x:Class="Vesper.App.Views.ServersView"
             x:DataType="vm:ServersViewModel">

  <Grid ColumnDefinitions="270,*">

    <Border Grid.Column="0" Background="{DynamicResource BgBaseBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
      <Grid RowDefinitions="Auto,*,Auto" Margin="16,20,16,16">

        <TextBlock Grid.Row="0" Classes="label" Text="SERVERS" Margin="4,0,0,12" />

        <ScrollViewer Grid.Row="1">
          <StackPanel>
            <ItemsControl ItemsSource="{Binding Servers}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="srv:ServerDefinition">
                  <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                    <Button Grid.Column="0" Classes="nav" Padding="10,9"
                            Command="{Binding $parent[UserControl].((vm:ServersViewModel)DataContext).SelectServerCommand}"
                            CommandParameter="{Binding}">
                      <StackPanel Orientation="Horizontal" Spacing="11">
                        <Path Classes="icon" Width="15" Height="15" Data="{StaticResource IconServer}" />
                        <StackPanel VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}" FontSize="12.5"
                                     Foreground="{DynamicResource TextPrimaryBrush}" />
                          <TextBlock Text="{Binding Summary}" FontSize="10"
                                     Foreground="{DynamicResource TextFaintBrush}" />
                        </StackPanel>
                      </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Classes="chrome" Width="30" Height="30"
                            Command="{Binding $parent[UserControl].((vm:ServersViewModel)DataContext).DeleteServerCommand}"
                            CommandParameter="{Binding}">
                      <Path Classes="icon" Width="13" Height="13" Data="{StaticResource IconTrash}" />
                    </Button>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Classes="subtitle" FontSize="12" Margin="6,10" TextWrapping="Wrap"
                       Text="No servers yet. Create one to get started."
                       IsVisible="{Binding !HasServers}" />
          </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Spacing="9" Margin="0,12,0,0">
          <StackPanel Spacing="8" IsVisible="{Binding IsCreating}">
            <TextBlock Classes="label" Text="NAME" />
            <TextBox Classes="field" PlaceholderText="Survival"
                     Text="{Binding NewServerName, Mode=TwoWay}" />
            <TextBlock Classes="label" Text="VERSION" />
            <ComboBox Classes="field" ItemsSource="{Binding Versions}"
                      SelectedItem="{Binding SelectedVersion, Mode=TwoWay}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Classes="primary" Padding="16,8" Content="Create"
                      Command="{Binding ConfirmCreateCommand}" />
              <Button Classes="ghost" Content="Cancel" Command="{Binding CancelCreateCommand}" />
            </StackPanel>
          </StackPanel>

          <Button Classes="ghost" HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  IsVisible="{Binding !IsCreating}"
                  Command="{Binding BeginCreateCommand}">
            <StackPanel Orientation="Horizontal" Spacing="9">
              <Path Classes="icon" Width="15" Height="15" Data="{StaticResource IconPlus}" />
              <TextBlock Text="New server" FontSize="12.5" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*,Auto" Margin="26,22,26,22">

      <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,16">
        <TextBlock Classes="title" Text="{Binding SelectedServer.Name, FallbackValue='Servers'}" />
        <TextBlock Classes="subtitle" Text="{Binding StatusText}" TextWrapping="Wrap" />
      </StackPanel>

      <Border Grid.Row="1" Classes="card" Margin="0,0,0,14" IsVisible="{Binding HasSelection}">
        <StackPanel Spacing="13">
          <StackPanel Orientation="Horizontal" Spacing="9">
            <Button Classes="primary" Padding="17,10"
                    IsEnabled="{Binding CanStart}" Command="{Binding StartCommand}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Path Classes="icon solid" Width="14" Height="14"
                      Fill="{DynamicResource AccentContrastBrush}"
                      Data="{StaticResource IconPlay}" />
                <TextBlock Text="Start" />
              </StackPanel>
            </Button>
            <Button Classes="ghost" IsEnabled="{Binding CanStop}" Command="{Binding StopCommand}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconStop}" />
                <TextBlock Text="Stop" FontSize="12.5" />
              </StackPanel>
            </Button>
            <Button Classes="ghost" IsEnabled="{Binding CanStop}" Command="{Binding RestartCommand}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconRefresh}" />
                <TextBlock Text="Restart" FontSize="12.5" />
              </StackPanel>
            </Button>
            <Button Classes="ghost" IsEnabled="{Binding !IsInstalled}" Command="{Binding InstallCommand}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconDownload}" />
                <TextBlock Text="Install" FontSize="12.5" />
              </StackPanel>
            </Button>
            <Button Classes="ghost" Command="{Binding OpenFolderCommand}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconFolder}" />
                <TextBlock Text="Folder" FontSize="12.5" />
              </StackPanel>
            </Button>
          </StackPanel>

          <ProgressBar Classes="slim" Value="{Binding Progress}" Maximum="100"
                       IsVisible="{Binding IsBusy}" />

          <Grid ColumnDefinitions="Auto,*">
            <StackPanel Orientation="Horizontal" Spacing="9">
              <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconGlobe}" />
              <TextBlock Classes="subtitle" FontSize="12" VerticalAlignment="Center"
                         Text="{Binding SelectedAddress}" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <Border Grid.Row="2" Classes="card" Padding="0" ClipToBounds="True">
        <Panel Background="{DynamicResource BgBaseBrush}">
          <ScrollViewer Padding="14">
            <ItemsControl ItemsSource="{Binding Console}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="sys:String">
                  <TextBlock Text="{Binding}" FontSize="11.5" FontFamily="Consolas,monospace"
                             TextWrapping="Wrap"
                             Foreground="{DynamicResource TextMutedBrush}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
          <TextBlock Text="Console output appears here" Classes="subtitle"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     IsVisible="{Binding !IsRunning}" />
        </Panel>
      </Border>

      <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
        <TextBox Grid.Column="0" Classes="field" Margin="0,0,9,0"
                 PlaceholderText="Type a server command"
                 IsEnabled="{Binding IsRunning}"
                 Text="{Binding CommandText, Mode=TwoWay}" />
        <Button Grid.Column="1" Classes="ghost" IsEnabled="{Binding IsRunning}"
                Command="{Binding SendCommandCommand}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconChevronRight}" />
            <TextBlock Text="Send" FontSize="12.5" />
          </StackPanel>
        </Button>
      </Grid>

    </Grid>
  </Grid>
</UserControl>
