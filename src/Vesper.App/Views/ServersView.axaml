<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vesper.App.ViewModels"
             x:Class="Vesper.App.Views.ServersView"
             x:DataType="vm:ServersViewModel">

  <ScrollViewer>
    <StackPanel Margin="30,24" Spacing="18" MaxWidth="820" HorizontalAlignment="Left">

      <StackPanel Spacing="6">
        <TextBlock Classes="title" Text="Servers" />
        <TextBlock Classes="subtitle" TextWrapping="Wrap"
                   Text="Run a Paper or Purpur server locally, manage plugins and mods, and share it over a playit.gg tunnel or your own domain." />
      </StackPanel>

      <Border Classes="card hoverable">
        <StackPanel Spacing="14">
          <TextBlock Classes="label" Text="CONTROLS" />
          <StackPanel Orientation="Horizontal" Spacing="9">
            <Button Classes="primary" Padding="17,10" IsEnabled="False">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Path Classes="icon solid" Width="14" Height="14"
                      Fill="{DynamicResource AccentContrastBrush}"
                      Data="{StaticResource IconPlay}" />
                <TextBlock Text="Start" />
              </StackPanel>
            </Button>
            <Button Classes="ghost" IsEnabled="False">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconStop}" />
                <TextBlock Text="Stop" FontSize="12.5" />
              </StackPanel>
            </Button>
            <Button Classes="ghost" IsEnabled="False">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconRefresh}" />
                <TextBlock Text="Restart" FontSize="12.5" />
              </StackPanel>
            </Button>
            <Button Classes="ghost" IsEnabled="False">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Path Classes="icon" Width="14" Height="14" Data="{StaticResource IconGlobe}" />
                <TextBlock Text="Tunnel" FontSize="12.5" />
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Classes="label" Text="CONSOLE" />
          <Border Background="{DynamicResource BgBaseBrush}" CornerRadius="11" Height="230"
                  BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
            <TextBlock Text="No server running" Classes="subtitle" FontFamily="Consolas,monospace"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBox Classes="field" PlaceholderText="Type a server command" IsEnabled="False" />
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="8">
          <TextBlock Classes="label" Text="SERVER DIRECTORY" />
          <SelectableTextBlock Text="{Binding ServersDirectory}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextMutedBrush}" />
          <TextBlock Classes="subtitle" FontSize="11.5" TextWrapping="Wrap"
                     Text="Server management is the next milestone. The launcher already reserves this folder for it." />
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
